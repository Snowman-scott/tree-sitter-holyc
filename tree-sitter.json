{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "holyc",
      "camelcase": "Holyc",
      "title": "HolyC",
      "scope": "source.holyc",
      "file-types": [
        "hc"
      ],
      "injection-regex": "^holyc$",
      "class-name": "TreeSitterHolyc"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "AGPL",
    "description": "Tree-sitter grammar for the HolyC programming language (from TempleOS, made by Terry A. Davis)",
    "authors": [
      {
        "name": "Epicwoman212",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/Snowman-scott/tree-sitter-holyc.git",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
